# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=5214
APP_HOST=0.0.0.0
APP_ENV=development

# SQLite database file (relative to backend/ or absolute)
SQLITE_DB=data/gtm.sqlite

# ── CORS (comma separated) ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5314,http://127.0.0.1:5314

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# IMPORTANT: change to a long random string in production. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_HOURS=24
# Set to "false" once you have created your first admin user
ALLOW_REGISTRATION=true

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ── LLM (at least ONE provider key required for LLM features) ───────────────
# Heuristic adapters are used as fallback when none of these are set.
OPENAI_APIKEY=
ANTHROPIC_API_KEY=
GOOGLE_GENAI_APIKEY=
VERTEXAI_APIKEY=

# Toggle LLM features (default: true)
USE_LLM_DRAFTER=true
USE_LLM_CLASSIFIER=true
LLM_REPLY_MODEL=gpt-4o-mini

# ── Email sending ────────────────────────────────────────────────────────────
# EMAIL_PROVIDER selects the active sender at startup.
# Options: fake | smtp | sendgrid | postmark
EMAIL_PROVIDER=fake

# SMTP (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_USE_TLS=true

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=
SENDGRID_FROM=
SENDGRID_FROM_NAME=

# Postmark (used when EMAIL_PROVIDER=postmark)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM=
POSTMARK_STREAM=outbound

# ── Error monitoring (optional) ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_RATE=0.0
